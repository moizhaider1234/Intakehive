# IntakeHive Backend — Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 3001)
PORT=3001

# Admin API key — used for all GET/DELETE routes
# Change this to something secure before deploying!
ADMIN_KEY=IntakeHive2026
TRUSTEDFORM_API_KEY=0a3d23f23291fd796a49bf7978a5ee3a
# Comma-separated list of allowed CORS origins
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Leave blank to allow all origins (development only)
ALLOWED_ORIGINS=
